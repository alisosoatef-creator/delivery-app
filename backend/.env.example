# Local backend environment example. Set these in your shell or process manager.
# Do not put real secrets in this file.

NODE_ENV=development
HOST=127.0.0.1
PORT=3001
APP_NAME=Wasel

# SQLite is local-development only. The app also accepts WASEL_DB_PATH for legacy scripts.
SQLITE_DB_PATH=backend/dev.sqlite
DATABASE_URL=sqlite:backend/dev.sqlite

DEV_ADMIN_ENABLED=true
DEV_DRIVER_ENABLED=true
OTP_MODE=dev
DEV_OTP_CODE=1234
PAYMENT_MODE=placeholder
ROUTING_PROVIDER=osrm-public-demo
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
