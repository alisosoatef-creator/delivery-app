# Local frontend environment example. Copy to .env.local if you need overrides.
# Do not put real secrets in this file.

NODE_ENV=development
APP_NAME=Wasel
VITE_APP_NAME=Wasel
VITE_API_BASE_URL=/api
VITE_SOCKET_URL=/
VITE_DEV_ADMIN_ENABLED=true
VITE_DEV_DRIVER_ENABLED=true
VITE_OTP_MODE=dev
VITE_PAYMENT_MODE=placeholder
VITE_ROUTING_PROVIDER=osrm-public-demo
