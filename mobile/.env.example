EXPO_PUBLIC_APP_NAME=Wasel
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:3001/api
EXPO_PUBLIC_SOCKET_URL=http://127.0.0.1:3001
EXPO_PUBLIC_OTP_MODE=dev
EXPO_PUBLIC_PAYMENT_MODE=placeholder

# Android emulator often needs:
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3001/api
# EXPO_PUBLIC_SOCKET_URL=http://10.0.2.2:3001
#
# Real phones need your computer LAN IP:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.20:3001/api
# EXPO_PUBLIC_SOCKET_URL=http://192.168.1.20:3001
