{
  "expo": {
    "name": "وصل",
    "slug": "wasel-delivery",
    "scheme": "wasel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06070a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wasel.delivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "يستخدم وصل موقعك لتحديد نقطة الانطلاق وتتبع الكابتن أثناء الرحلة."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#06070a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.wasel.delivery"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
