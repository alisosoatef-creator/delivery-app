{
  "expo": {
    "name": "Wasel",
    "slug": "wasel-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "wasel",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#0A1020"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"]
  }
}
